{
  "manifest_version": 3,
  "name": "Web Summarizer",
  "version": "0.1.0",
  "description": "Summarize any webpage with AI.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.openai.com/"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Summarize this page"
  }
}
